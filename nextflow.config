//
// Nextflow config for nucDetective MNase-seq pipeline
//

/*
 * Container engine
 * Supported values: 'docker' or 'singularity'
 */
params.container_engine = 'docker'

/*
 * Global default parameters
 */
params {

    // Workflow
    analysis              = 'profiler'
    inspector             = false
    help                  = false
    test                  = false

    // Input / output
    csvInput              = "$projectDir/toyData/samples_profiler.csv"
    outDir                = "$HOME/nucDetective_test"
    project               = "$projectDir"
    tracedir              = "${params.outDir}/pipeline_info"

    // Reference files
    genomeIdx             = "$projectDir/toyData/Bowtie2Index/genome_chr3R"
    chrSizes              = "$projectDir/toyData/chrom_Sizes.txt"
    TSS                   = false
    blacklist             = false
    nrl_regions           = false

    // General options
    genomeSize            = 3000000
    publishBam            = false
    publishBamFlt         = true
    OmitPublishWig        = false
    MAPQC                 = 20

    // Fragment length selection
    minLen                = 140
    maxLen                = 200

    // NRL settings
    peaks_used            = 7
    avgNRL                = 180

    // Analysis options
    detect_shift          = true
    normalize_profiles    = true
    regularity_ref        = true
}

/*
 * Process configuration
 */
process {

    // Default container for most processes
    container = 'uschwartz/core_docker:v1.0'

    // Processes that require the NRL container
    withName: 'NRL|NRL_overview' {
        container = 'leoschmutterer/nrl:v2.1'
    }

    // Process that requires the NRL regions container
    withName: 'compare_NRL_regions' {
        container = 'leoschmutterer/nrl_regions:v1.1'
    }

    // CPU resources by label
    withLabel: big {
        cpus = 4
    }

    withLabel: mid {
        cpus = 2
    }

    withLabel: small {
        cpus = 1
    }
}

/*
 * Container engine setup
 */
if( !['docker', 'singularity'].contains(params.container_engine) ) {
    throw new IllegalArgumentException(
        "Invalid container engine: '${params.container_engine}'. Please use 'docker' or 'singularity'."
    )
}

if( params.container_engine == 'docker' ) {
    docker {
        enabled    = true
        runOptions = '-u $(id -u):$(id -g)'
    }
    singularity.enabled = false
}

if( params.container_engine == 'singularity' ) {
    singularity {
        enabled    = true
        autoMounts = true
    }
    docker.enabled = false
}

/*
 * Test-mode overrides
 */
if( params.test ) {
    params.TSS       = "$projectDir/toyData/dm3.refGene_chr3R_cut.gtf"
    params.blacklist = "$projectDir/toyData/dm3-blacklistChromosomes_chr3R_cut.bed"

    if( params.analysis == 'profiler' ) {
        params.csvInput   = "$projectDir/toyData/samples_profiler.csv"
        params.outDir     = "$launchDir/Profiler_test"
        params.tracedir   = "${params.outDir}/pipeline_info"
        params.peaks_used = 3
    }

    if( params.analysis == 'inspector' ) {
        params.csvInput           = "$projectDir/toyData/samples_inspector.csv"
        params.outDir             = "$launchDir/Inspector_test"
        params.tracedir           = "${params.outDir}/pipeline_info"
        params.normalize_profiles = false
    }
}

/*
 * Pipeline metadata
 */
manifest {
    name        = 'uschwartz/nucDetective'
    author      = 'Uwe Schwartz'
    description = 'Nextflow MNase-seq analysis pipeline'
    mainScript  = 'main.nf'
    version     = '1.0.1'
}

/*
 * Execution reports
 */
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/execution_timeline.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/execution_report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/execution_trace.txt"
}
