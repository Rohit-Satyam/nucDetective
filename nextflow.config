
//                     nextflow based MNase-seq pipeline config


// container settings

params.container_engine = 'docker' // docker (default) or singularity
process.container = 'uschwartz/core_docker:v1.0'

if (params.container_engine == 'singularity') {
    singularity {
        enabled = true
        autoMounts = true
    }
    docker.enabled = false
} 

if (params.container_engine == 'docker') {
    docker {
        enabled = true
        runOptions = '-u $(id -u):$(id -g)'
    }
    singularity.enabled = false
}

// Error handling for invalid container engine
if (params.container_engine != 'docker' && params.container_engine != 'singularity') {
    System.err.println("ERROR: Invalid container engine: '${params.container_engine}'. Please use either 'docker' or 'singularity'.")
    System.exit(1)
}



// Global default params, used in configs
params {
  //                    Workflow
  analysis="profiler"
  inspector=false

  //                    Directories
  // path to Input
  csvInput="$projectDir/toyData/samples_profiler.csv"
  // path to Output
  outDir="$HOME/nucDetective_test/"
  // path to project
  project="$projectDir"
  // path to pipeline running reports
  tracedir = "${params.outDir}/pipeline_info"
  // path to bowtie2 index
  genomeIdx="$projectDir/toyData/Bowtie2Index/genome_chr3R"
  // path to chrSizes
  chrSizes="$projectDir/toyData/chrom_Sizes.txt"


  //                    Options
  help=false
  // path to reference file for TSS plots
  TSS=false
  //Path to file for filtering regions
  //blacklist="$projectDir/toyData/dm3-blacklist_Chromosomes.bed"
  blacklist=false
  //efective genome size for normalisation
  genomeSize= 3000000
  // whether to publish bam files
  publishBam=false
  // whether to publish size selected bam files
  publishBamFlt=true
  // whether to publish wig files
  OmitPublishWig=false
  // test RUN with toyData
  test = false
  //filter MAPQC
  MAPQC=20
  // length for mono-nucleosome selection
  minLen=140
  maxLen=200
  // NRL number of peaks used
  peaks_used = 7
  // detect nucleosome shifts
  detect_shift=true
  //normalize profiles
  normalize_profiles=true
  //use reference map for regularity
  regularity_ref=true
  //regions for NRL_regions
  nrl_regions=false
  //average NRL used in nucleosome regularity analysis
  avgNRL=180

}

// change optional params for test RUN with toyData

if (params.test) {
  params.TSS = "$projectDir/toyData/dm3.refGene_chr3R_cut.gtf"
  params.blacklist = "$projectDir/toyData/dm3-blacklistChromosomes_chr3R_cut.bed"

  //additional options for Profiler test RUN
  if (params.analysis == "profiler") {
    params.csvInput = "$projectDir/toyData/samples_profiler.csv"
    params.outDir="$launchDir/Profiler_test"
    params.tracedir = "${params.outDir}/pipeline_info"
    params.peaks_used = 3
    }
  if (params.analysis == "inspector") {
    params.csvInput = "$projectDir/toyData/samples_inspector.csv"
    params.outDir="$launchDir/Inspector_test"
    params.tracedir = "${params.outDir}/pipeline_info"
    params.normalize_profiles=false
    }
}


process {
    withLabel: big {
        cpus = 4
    }
    withLabel: mid {
        cpus = 2
    }
    withLabel: small {
        cpus = 1
    }
}


// reporting

manifest {
  name = 'uschwartz/nucDetective'
  author = 'Uwe Schwartz'
  description = 'Nextflow MNase-seq analysis pipeline'
  mainScript = 'main.nf'
  version = '01.0.0'
}

// pipeline reports
timeline {
  enabled = true
  overwrite = true
  file = "${params.tracedir}/execution_timeline.html"
}
report {
  enabled = true
  overwrite = true
  file = "${params.tracedir}/execution_report.html"
}
trace {
  enabled = true
  overwrite = true
  file = "${params.tracedir}/execution_trace.txt"
  trace.overwrite = true
}
